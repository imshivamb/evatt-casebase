# Copy this to .env and fill in your key.
# Streaming AI summaries are automatically disabled if the key is absent.
OPENAI_API_KEY=

# Optional — defaults to gpt-5.4-mini (OpenAI’s latest capable mini).
# OPENAI_SUMMARY_MODEL=gpt-5.4-mini

# Optional — extra CORS origins (comma-separated), e.g. Vercel preview URLs.
# CORS_ORIGINS=https://evatt-casebase-git-main-xxx.vercel.app
